# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database (for local development, Docker Compose sets this automatically)
# DATABASE_URL=postgresql://cashflow:cashflow_secret@localhost:5432/cashflow

# For SQLite fallback (not recommended for production)
# USE_SQLITE=true
# CASHFLOW_DB=cashflow.db
